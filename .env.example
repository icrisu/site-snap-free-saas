NEXT_PUBLIC_BASE_URL=http://localhost:3000
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# BROWSER_PROVIDER determines which Chromium browser backend to use for PDF generation and other Playwright tasks.
# Options:
#   "playwright" - Use the standard Playwright Chromium browser. Recommended for Node.js servers or local development environments (non-serverless deployments). Not optimized for serverless platforms.
#   "sparticuz"  - Use @sparticuz/chromium, a serverless-optimized Chromium binary. Ideal for serverless platforms like Vercel, Netlify, or AWS Lambda.
# If not set, defaults to "playwright".
# Example:
# BROWSER_PROVIDER=sparticuz or BROWSER_PROVIDER=playwright
BROWSER_PROVIDER=playwright
# PDF_LOAD_IMAGES_STRATEGY controls how images are being loaded when generating PDFs.
# Options:
#   "default" - Generate PDF immediately without extra processing. Some images (especially lazy-loaded ones at the bottom of the page) may not appear.
#   "full"    - Ensures all images load before PDF generation by disabling lazy-loading, scrolling the page, and waiting for all images to finish loading. Use this if you need a complete PDF with every image displayed.
# Uncomment the line below to enable the full loading strategy:
PDF_LOAD_IMAGES_STRATEGY=full

# Database (postgresql)
DATABASE_URL=""

# NextAuth
AUTH_SECRET=""
AUTH_URL=http://localhost:3000

# App branding keys
SITE_NAME=SiteSnap
NEXT_PUBLIC_PDF_DOWNLOAD_FILENAME=sitesnap-edited.pdf
NEXT_PUBLIC_THEME_STORAGE_KEY=sitesnap-theme
NEXT_PUBLIC_CONSENT_COOKIE_KEY=sitesnap-consent
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Set to true to hide Pricing and Sign In UI (for self-hosted / no-payment deployments)
DISABLE_SIGNUP_PAYMENTS=false