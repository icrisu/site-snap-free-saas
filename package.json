{
  "name": "site-snap",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "seed:admin": "tsx prisma/seed-plans.ts && tsx prisma/seed-admin.ts",
    "seed:customer": "tsx prisma/seed-plans.ts && tsx prisma/seed-customer.ts",
    "seed:plans": "tsx prisma/seed-plans.ts",
    "seed:all": "tsx prisma/seed-plans.ts && tsx prisma/seed-admin.ts && tsx prisma/seed-customer.ts",
    "type-check": "tsc --noEmit",
    "check": "npm run lint && npm run type-check"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.986.0",
    "@hookform/resolvers": "^5.2.2",
    "@paddle/paddle-js": "^1.6.2",
    "@paddle/paddle-node-sdk": "^3.6.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@sparticuz/chromium": "^143.0.4",
    "axios": "^1.13.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.12",
    "konva": "^9.3.22",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.8.2",
    "pdf-lib": "^1.17.1",
    "pg": "^8.18.0",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "puppeteer-core": "^24.37.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-konva": "^19.2.2",
    "react-pdf": "^10.3.0",
    "resend": "^6.9.1",
    "tailwind-merge": "^3.4.0",
    "tsx": "^4.21.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.3.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "@auth/core": "0.41.1"
  }
